# TechScreen — environment template
#
# Copy this file to `.env` for local dev. `.env` is gitignored.
# Never put real secrets in this file. Non-secret defaults (enums, public
# URLs, placeholder domains) are allowed and expected — see ADR-022.
# Never commit `.env`.
#
# In the cloud, secret values come from Secret Manager via Workload Identity
# Federation (ADR-013). This file is the canonical list of keys — any new
# secret key added here must also be added to `local.secret_names` in
# `infra/terraform/modules/environment/main.tf` (shells are created for BOTH
# environments — dev names get a `_DEV` suffix per ADR-023), then filled in
# Secret Manager manually after `terraform apply`.
# See `docs/engineering/cloud-setup.md` § Secret Manager inventory.

# ---------------------------------------------------------------------------
# Runtime selectors
# ---------------------------------------------------------------------------

# One of: dev, test, prod. The canonical runtime selector — set by Dockerfile
# / docker-compose / Cloud Run wiring. The backend Settings class reads this
# to enforce FR-007 (prod refuses LLM_BACKEND=mock at boot) and the §12
# per-session budget ceiling.
APP_ENV=dev

# One of: mock, vertex. Prod must be `vertex`.
LLM_BACKEND=mock

# Per-session LLM cost ceiling in USD. Constitution §12 caps prod at $5.00.
LLM_BUDGET_PER_SESSION_USD=5.00

# Mock-mode fixture root. Ignored when LLM_BACKEND=vertex. Override only when
# running tests from a non-standard working directory; the in-code default
# (Settings.llm_fixtures_dir) points at the repo path under app/backend/tests/.
# Left blank in .env.example to avoid the >32-char opaque-string guardrail.
# LLM_FIXTURES_DIR=

# Structured JSON logs to stdout (Cloud Run scrapes these).
LOG_FORMAT=json
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Full SQLAlchemy URL. In dev with `docker compose up`, leave empty —
# docker-compose.yml explicitly sets DATABASE_URL to the compose `postgres`
# service. Fill here only when running the backend outside compose.
# In prod, populated from Secret Manager; Cloud Run → Cloud SQL via the
# Cloud SQL Proxy sidecar.
DATABASE_URL=

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------

# One of: disabled, identity_platform. The §9 dark-launch seam for staff SSO
# (T07, ADR-024). `disabled` (default) keeps every authenticated endpoint
# dark (401 — the pre-T07 posture): local dev and tests need no real tokens.
# Flip to identity_platform per environment on Cloud Run (dev first) after
# the operator runbook in specs/021-t07-identity-sso/quickstart.md.
# Requires GCP_PROJECT (the ID-token audience) when enabled.
AUTH_MODE=disabled

# Google Workspace hosted domain admitted by the SSO middleware (not a
# secret; ADR-016/ADR-024). Tokens whose `hd`/email domain differ are 401.
AUTH_ALLOWED_DOMAIN=n-ix.com

# Signing key for magic links (HMAC). Generate locally with:
#   openssl rand -hex 32
# Rotate via a new Secret Manager version in prod.
MAGIC_LINK_SIGNING_KEY=

# Secret for the recruiter session cookie. Generate locally with:
#   openssl rand -hex 32
# Rotate with care in prod — invalidates active sessions.
SESSION_COOKIE_SECRET=

# ---------------------------------------------------------------------------
# Email (magic links + recruiter notifications)
# ---------------------------------------------------------------------------

SENDGRID_API_KEY=

# From address for outgoing mail. Not a secret; here for completeness.
MAIL_FROM_ADDRESS=no-reply@techscreen.example

# ---------------------------------------------------------------------------
# Vertex AI / GCP
# ---------------------------------------------------------------------------

# GCP project id. Not a secret.
GCP_PROJECT=
GCP_LOCATION=europe-west1

# ---------------------------------------------------------------------------
# Calibration
# ---------------------------------------------------------------------------

# Encryption key for labelled calibration datasets (optional at MVP).
CALIBRATION_DATASET_KEY=

# ---------------------------------------------------------------------------
# Frontend (public — prefixed with NEXT_PUBLIC_)
# ---------------------------------------------------------------------------

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_ENV=dev
