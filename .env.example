# TechScreen — environment template
#
# Copy this file to `.env` for local dev. `.env` is gitignored.
# Never put real values in this file. Never commit `.env`.
#
# In prod, values come from Secret Manager via Workload Identity Federation
# (ADR-013). This file is the canonical list of keys — any new key added
# here must also be declared as a `google_secret_manager_secret` in
# `infra/terraform/secrets.tf`, and filled in Secret Manager manually after
# `terraform apply`. See `docs/cloud-setup.md`.

# ---------------------------------------------------------------------------
# Runtime selectors
# ---------------------------------------------------------------------------

# One of: dev, test, prod. Prod refuses LLM_BACKEND=mock at boot.
APP_ENV=dev

# One of: mock, vertex. Prod must be `vertex`.
LLM_BACKEND=mock

# Structured JSON logs to stdout (Cloud Run scrapes these).
LOG_FORMAT=json
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Full SQLAlchemy URL. In dev, points at the compose `postgres` service.
# In prod, populated from Secret Manager; Cloud Run → Cloud SQL via the
# Cloud SQL Proxy sidecar.
DATABASE_URL=

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------

# Signing key for magic links (HMAC). Rotate via a new Secret Manager version.
MAGIC_LINK_SIGNING_KEY=

# Secret for the recruiter session cookie. Rotate with care — invalidates
# active sessions.
SESSION_COOKIE_SECRET=

# ---------------------------------------------------------------------------
# Email (magic links + recruiter notifications)
# ---------------------------------------------------------------------------

SENDGRID_API_KEY=

# From address for outgoing mail. Not a secret; here for completeness.
MAIL_FROM_ADDRESS=no-reply@techscreen.example

# ---------------------------------------------------------------------------
# Vertex AI / GCP
# ---------------------------------------------------------------------------

# GCP project id. Not a secret.
GCP_PROJECT=
GCP_LOCATION=europe-west1

# In dev, this is the vertex-mock service URL (see docker-compose.yml).
# In prod, leave blank — the backend uses the Vertex SDK directly.
VERTEX_MOCK_URL=http://vertex-mock:8080

# ---------------------------------------------------------------------------
# Calibration
# ---------------------------------------------------------------------------

# Encryption key for labelled calibration datasets (optional at MVP).
CALIBRATION_DATASET_KEY=

# ---------------------------------------------------------------------------
# Frontend (public — prefixed with NEXT_PUBLIC_)
# ---------------------------------------------------------------------------

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_ENV=dev
