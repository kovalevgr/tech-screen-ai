# syntax=docker/dockerfile:1.7
# vertex-mock — a small FastAPI service that mimics the shape of the Vertex
# adapter's responses. Used in dev (LLM_BACKEND=mock) and in CI. Prod never
# runs this image; the backend refuses to start in prod with LLM_BACKEND=mock
# (constitution §17, ADR-010).
#
# Canned responses live under tools/vertex-mock/fixtures/, keyed by a hash of
# (agent, prompt_version, system_prompt, user_payload). If a key misses, the
# mock returns a deterministic "stub" reply and logs the miss — useful signal
# that a fixture should be added.

FROM python:3.12-slim-bookworm AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PATH="/app/.venv/bin:${PATH}" \
    MOCK_PORT=8080 \
    LOG_FORMAT=json

RUN apt-get update \
 && apt-get install -y --no-install-recommends tini ca-certificates curl \
 && rm -rf /var/lib/apt/lists/*

RUN useradd --system --create-home --uid 10001 --shell /usr/sbin/nologin mock

WORKDIR /app

# Minimal deps — this service is intentionally tiny.
RUN python -m venv /app/.venv \
 && /app/.venv/bin/pip install --no-cache-dir \
        "fastapi==0.115.*" \
        "uvicorn[standard]==0.30.*" \
        "pydantic==2.*"

COPY tools/vertex-mock /app/vertex_mock

RUN chown -R mock:mock /app

USER mock

EXPOSE 8080

HEALTHCHECK --interval=5s --timeout=3s --retries=5 \
    CMD curl -fsS "http://localhost:${MOCK_PORT}/healthz" || exit 1

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["uvicorn", "vertex_mock.main:app", \
     "--host", "0.0.0.0", \
     "--port", "8080"]
