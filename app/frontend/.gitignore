# TechScreen frontend — local artefacts.
# Repo-root .gitignore covers most of these; this file keeps the frontend
# self-contained for tools that scope to the nearest .gitignore.

node_modules/
.next/
dist/
out/
coverage/
.turbo/

# Log + debug output.
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local env overrides (public env still lives in NEXT_PUBLIC_* vars — not here).
.env*.local
